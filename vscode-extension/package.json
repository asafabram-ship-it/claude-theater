{
  "name": "claude-theater",
  "displayName": "Claude Theater",
  "description": "Watch your Claude Code conversations and subagents work — a live office, inside VS Code.",
  "version": "0.2.4",
  "publisher": "asafabram-ship-it",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": { "color": "#0b1020", "theme": "dark" },
  "pricing": "Free",
  "repository": { "type": "git", "url": "https://github.com/asafabram-ship-it/claude-theater" },
  "bugs": { "url": "https://github.com/asafabram-ship-it/claude-theater/issues" },
  "homepage": "https://github.com/asafabram-ship-it/claude-theater#readme",
  "engines": { "vscode": "^1.80.0" },
  "categories": ["Visualization", "Other"],
  "keywords": ["claude", "claude code", "agents", "subagents", "visualization"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "scripts": {
    "vscode:prepublish": "node -e \"require('fs').copyFileSync('../claude_theater.py','claude_theater.py')\""
  },
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeTheaterContainer",
          "title": "Claude Theater",
          "icon": "icon.png"
        }
      ]
    },
    "views": {
      "claudeTheaterContainer": [
        {
          "id": "claudeTheater.view",
          "name": "Theater",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "claudeTheater.open",
        "title": "Open Theater",
        "category": "Claude Theater"
      },
      {
        "command": "claudeTheater.menu",
        "title": "Menu (start / stop / open)",
        "category": "Claude Theater"
      }
    ],
    "configuration": {
      "title": "Claude Theater",
      "properties": {
        "claudeTheater.port": {
          "type": "number",
          "default": 7333,
          "description": "Port the Claude Theater server listens on (127.0.0.1)."
        },
        "claudeTheater.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Automatically run the Claude Theater server in the background when VS Code starts. Toggle this from the status-bar button."
        },
        "claudeTheater.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to the Python interpreter used to run the server. Empty = try `python`, then `py`, then `python3`."
        },
        "claudeTheater.serverScript": {
          "type": "string",
          "default": "",
          "description": "Optional path to claude_theater.py. Empty = use the copy bundled with the extension (no install needed)."
        }
      }
    }
  }
}
